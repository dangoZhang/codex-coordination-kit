{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewGateResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW_MERGE_TO_BASE",
        "BLOCK_MERGE_TO_BASE"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "file": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "severity",
          "file",
          "note"
        ]
      }
    },
    "tests_recommended": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "decision",
    "summary",
    "findings",
    "tests_recommended"
  ]
}
